# Copy to .env and fill in. Never commit the real file.

# Postgres connection string
DATABASE_URL="postgresql://dutchie:dutchie@localhost:5432/dutchie?schema=public"

# JWT signing secrets — generate with: openssl rand -base64 32
# The server refuses to boot in production if these still say "change-me".
JWT_ACCESS_SECRET="change-me-dev-access-secret"
JWT_REFRESH_SECRET="change-me-dev-refresh-secret"

# Optional (defaults shown)
PORT=4000
NODE_ENV=development
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
