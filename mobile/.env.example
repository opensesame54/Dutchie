# Copy to .env. Expo inlines EXPO_PUBLIC_* vars at build time, so this must not
# hold anything secret — it is the public API origin only.
#
#   Android emulator     -> http://10.0.2.2:4000
#   Physical device      -> http://<your-machine-LAN-IP>:4000
#   Staging / production -> https://api.yourdomain.com
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000
