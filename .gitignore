# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Test output
coverage/

# Secrets. Everything .env* is ignored EXCEPT the committed templates, so a
# real credential file can never be added by accident.
.env
.env.*
!.env.example
!.env.*.example

# Expo / Metro
.expo/
.expo-shared/
web-build/
expo-env.d.ts
.metro-health-check*

# Generated native projects — regenerated by `expo prebuild`, never edited by
# hand in this project. Anchored so a source directory named android/ or ios/
# elsewhere in the tree is not silently ignored.
/mobile/android/
/mobile/ios/

# Signing material and build artifacts. These must never reach the repo.
*.apk
*.aab
*.jks
*.keystore
*.p8
*.p12
*.key
*.pem
*.mobileprovision

# Logs
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# Local tooling state
.claude/settings.local.json
**/.claude/settings.local.json

# Editors / OS
.DS_Store
.idea/
.vscode/
*.swp
